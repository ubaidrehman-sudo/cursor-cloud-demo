generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id        Int        @id @default(autoincrement())
  title     String
  status    TaskStatus @default(TODO)
  createdAt DateTime   @default(now())
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}
